generator client {
  provider        = "prisma-client"
  output          = "./generated/prisma"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  subject   String
  message   String?
  createdAt DateTime @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  price       Int
  description String
  sizes       String[]
  colors      String[]
  rating      Int
  productType String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  category    String[]
  images      Image[]
}

model Image {
  id            String   @id @default(cuid())
  name          String
  url           String
  resource_type String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  // aboutTeamMember AboutTeamMember @relation(fields: [teamMemberId], references: [id])
  // teamMemberId    String          @unique
}

model About {
  id          String            @id @default(cuid())
  pageTitle   String
  description String
  coreValues  AboutCoreValue[]
  teamMembers AboutTeamMember[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model AboutTeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  // image     Image?
  bio       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  aboutId   String
  about     About    @relation(fields: [aboutId], references: [id])
}

model AboutCoreValue {
  id          String   @id @default(cuid())
  valueTitle  String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  aboutId     String
  about       About    @relation(fields: [aboutId], references: [id])
}

model ContactInfo {
  id              String   @id @default(cuid())
  title           String
  subTitle        String
  phone           String
  openingHours    String
  email           String
  emailSubText    String
  location        String
  locationSubText String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Video {
  id            String   @id @default(cuid())
  name          String
  url           String
  resource_type String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  homeInfoId    String   @unique
  homeInfo      HomeInfo @relation(fields: [homeInfoId], references: [id])
}

model HomeInfo {
  id               String   @id @default(cuid())
  title            String
  titleDescription String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  video            Video?
}

model BuyNow {
  id          String   @id @default(cuid())
  productId   String
  quantity    Int
  color       String
  size        String
  productName String
  fullname    String
  email       String
  phoneNumber String
  fullAddress String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
